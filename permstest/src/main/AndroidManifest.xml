<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Embedded Shizuku: declare the same API permission that the upstream manager uses.
      The server grants this as a runtime permission when apps request Shizuku access.
      In internal mode, the "manager" and client are the same package.
    -->
    <!--
        NOTE:
        Do NOT redeclare Shizuku's upstream permission name (moe.shizuku.manager.permission.API_V23).
        If the user has Shizuku installed, that permission is already owned by the manager package
        and APK install will fail with INSTALL_FAILED_DUPLICATE_PERMISSION.

        For the embedded/internal Shizuku mode, we use a host-app-scoped permission name.
     -->
    <permission
        android:name="${applicationId}.permission.SHIZUKU_API_V23"
        android:label="@string/perm_shizuku_api_label"
        android:description="@string/perm_shizuku_api_desc"
        android:protectionLevel="signature" />

    <!-- Required to talk to Shizuku / Sui on Android 6.0+ -->
    <!-- External Shizuku (default mode) -->
            <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
<uses-permission android:name="moe.shizuku.manager.permission.API_V23" />
    <!-- Embedded/internal Shizuku (opt-in) -->
    <uses-permission android:name="${applicationId}.permission.SHIZUKU_API_V23" />

    <!-- Needed to fetch APK URLs from GitHub/update sources and download them. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Optional all-files access for local Android FTP/file fallback paths. Shizuku remains the preferred privileged backend. -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />


    <!-- Used by the LADB overlay helper when running as a foreground service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Allow listing installed apps (test-bench convenience). Not Play-appropriate. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

        <!-- Optional: enables the floating LADB pairing helper overlay -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

