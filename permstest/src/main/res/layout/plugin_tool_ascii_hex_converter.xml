<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ASCII / Hex Converter"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Type text or byte values and the other side updates live. Supports hex, decimal, octal, binary, and common encodings."
                    android:textSize="12sp"
                    android:alpha="0.75"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilToolsAsciiEncoding"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Text encoding"
                        app:expandedHintEnabled="false"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/ddToolsAsciiEncoding"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:includeFontPadding="false"
                            android:paddingTop="12dp"
                            android:paddingStart="12dp"
                            android:paddingBottom="12dp"
                            android:paddingEnd="64dp"
                            android:gravity="center_vertical"
                            android:ellipsize="end"
                            android:completionThreshold="0"
                            android:inputType="none"
                            android:focusable="false"
                            android:singleLine="true"
                            android:scrollHorizontally="true"
                            android:textSize="13sp"
                            android:text="ASCII/UTF-8" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilToolsAsciiValueType"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:hint="Value type"
                        app:expandedHintEnabled="false"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/ddToolsAsciiValueType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:includeFontPadding="false"
                            android:paddingTop="12dp"
                            android:paddingStart="12dp"
                            android:paddingBottom="12dp"
                            android:paddingEnd="64dp"
                            android:gravity="center_vertical"
                            android:ellipsize="end"
                            android:completionThreshold="0"
                            android:inputType="none"
                            android:focusable="false"
                            android:singleLine="true"
                            android:scrollHorizontally="true"
                            android:textSize="13sp"
                            android:text="Hexadecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilToolsAsciiDelimiter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:hint="Delimiter"
                        app:expandedHintEnabled="false"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/ddToolsAsciiDelimiter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:includeFontPadding="false"
                            android:paddingTop="12dp"
                            android:paddingStart="12dp"
                            android:paddingBottom="12dp"
                            android:paddingEnd="64dp"
                            android:gravity="center_vertical"
                            android:ellipsize="end"
                            android:completionThreshold="0"
                            android:inputType="none"
                            android:focusable="false"
                            android:singleLine="true"
                            android:scrollHorizontally="true"
                            android:textSize="13sp"
                            android:text="Space" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilToolsAsciiCustomDelimiter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Custom delimiter"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtToolsAsciiCustomDelimiter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="56dp"
                        android:singleLine="true"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Text / ASCII">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtToolsAsciiText"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:gravity="top|start"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:scrollbars="vertical"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Values">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtToolsAsciiValues"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:gravity="top|start"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:scrollbars="vertical"
                        android:typeface="monospace"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/txtToolsAsciiStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Edit either box. Invalid byte tokens are ignored until corrected."
                    android:textSize="12sp"
                    android:alpha="0.75" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
