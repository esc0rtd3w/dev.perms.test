<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/tabMain"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:scrollbarStyle="insideOverlay">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgMainBanner"
android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="banner"
                    android:scaleType="fitCenter"
                    android:src="@drawable/banner_strip" />

                <TextView
                    android:id="@+id/txtDeviceProfileInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#101E2E"
                    android:gravity="center"
                    android:paddingLeft="10dp"
                    android:paddingTop="8dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="8dp"
                    android:text="@string/device_profile_info_default"
                    android:textColor="#DDEAF6"
                    android:textSize="12sp" />


                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMainBackend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutline"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingBottom="2dp"
                            android:tag="collapsible_groupbox_header">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Backend"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnMainBackendPopout"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="8dp"
                                android:contentDescription="Pop out Backend"
                                android:insetLeft="0dp"
                                android:insetTop="0dp"
                                android:insetRight="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:paddingLeft="6dp"
                                android:paddingRight="6dp"
                                android:text=""
                                app:icon="@drawable/ic_popout_open_in_new_24"
                                app:iconGravity="textStart"
                                app:iconTint="?attr/colorPrimary"
                                app:iconPadding="0dp"
                                app:iconSize="20dp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Choose the access backend and manage Shizuku, Internal Shizuku, LADB, and status checks."
                            android:textSize="12sp"
                            android:alpha="0.75"
                            android:paddingBottom="10dp" />
                                        <TextView
                                            android:id="@+id/txtStatus"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="12dp"
                                            android:paddingBottom="12dp"
                                            android:text="Status"
                                            android:textSize="16sp" />

                                        <include
                                            android:id="@+id/includeExecModeSelector"
                                            layout="@layout/include_execmode_selector" />

                                        <TextView
                                            android:id="@+id/txtShizukuOptionsHeader"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:text="Shizuku Options"
                                            android:textStyle="bold"
                                            android:paddingBottom="8dp" />

                                        <LinearLayout
                                            android:id="@+id/grpShizukuRow1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="8dp"
                                            android:orientation="horizontal">

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnRefresh"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_weight="1"
                                                android:text="Refresh status" />

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnRequest"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_marginStart="8dp"
                                                android:layout_weight="1"
                                                android:text="Request permission" />

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnRunId"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_marginStart="8dp"
                                                android:layout_weight="1"
                                                android:text="Fetch server info" />
                                        </LinearLayout>

                                        <LinearLayout
                                            android:id="@+id/grpShizukuRow2"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="8dp"
                                            android:orientation="horizontal">

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnOpenShizuku"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_weight="1"
                                                android:text="Open" />

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnStartShizuku"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_marginStart="8dp"
                                                android:layout_weight="1"
                                                android:text="Start" />

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnDownloadShizuku"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_marginStart="8dp"
                                                android:layout_weight="1"
                                                android:text="Download" />

                                        </LinearLayout>


                                        <TextView
                                            android:id="@+id/txtInternalShizukuOptionsHeader"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="28dp"
                                            android:paddingBottom="8dp"
                                            android:text="Internal Shizuku Options"
                                            android:textStyle="bold"
                                            android:visibility="gone" />

                                        <TextView
                                            android:id="@+id/txtInternalShizukuModeHint"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginBottom="6dp"
                                            android:alpha="0.8"
                                            android:text="Internal Shizuku uses its own Wireless Debugging pairing and server connection. After its binder is connected, no separate Request Permission prompt is needed."
                                            android:textSize="12sp"
                                            android:visibility="gone" />

                                        <LinearLayout
                                            android:id="@+id/rowInternalShizukuButtons"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="2dp"
                                            android:orientation="horizontal"
                                            android:visibility="gone">

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnInternalShizukuPairStart"
                                                style="@style/Widget.MaterialComponents.Button"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_weight="1"
                                                android:text="Pair &amp; Start" />

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnInternalShizukuStartServer"
                                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_marginStart="8dp"
                                                android:layout_weight="1"
                                                android:text="Start Server" />

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnInternalShizukuStopServer"
                                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_marginStart="8dp"
                                                android:layout_weight="1"
                                                android:text="Stop Server" />

                                        </LinearLayout>

                                        <LinearLayout
                                            android:id="@+id/rowInternalShizukuWirelessSettings"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="8dp"
                                            android:orientation="horizontal"
                                            android:visibility="gone">

                                            <com.google.android.material.button.MaterialButton
                                                android:id="@+id/btnInternalShizukuWirelessSettings"
                                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:text="Wireless Settings" />

                                        </LinearLayout>

                                        <TextView
                                            android:id="@+id/txtInternalShizukuPairHint"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="4dp"
                                            android:text="Tip: Open Wireless debugging → Pair device with pairing code. PermsTest will auto-detect the port; you only enter the 6-digit code."
                                            android:textSize="12sp"
                                            android:alpha="0.8"
                                            android:visibility="gone" />

                                        <TextView
                                            android:id="@+id/txtLadbOptionsHeader"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="8dp"
                                            android:text="LADB Options"
                                            android:textStyle="bold"
                                            android:visibility="gone" />

                                        <include
                                            android:id="@+id/includeExecModeLadb"
                                            layout="@layout/include_execmode_ladb"
                                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMainHome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutline"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingBottom="2dp"
                            android:tag="collapsible_groupbox_header">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Home"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnMainHomePopout"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="8dp"
                                android:contentDescription="Pop out Home"
                                android:insetLeft="0dp"
                                android:insetTop="0dp"
                                android:insetRight="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:paddingLeft="6dp"
                                android:paddingRight="6dp"
                                android:text=""
                                app:icon="@drawable/ic_popout_open_in_new_24"
                                app:iconGravity="textStart"
                                app:iconTint="?attr/colorPrimary"
                                app:iconPadding="0dp"
                                app:iconSize="20dp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Launcher mode, HOME behavior, and the App Tray shortcuts live here."
                            android:textSize="12sp"
                            android:alpha="0.75"
                            android:paddingBottom="10dp" />
                                        <com.google.android.material.checkbox.MaterialCheckBox
                                            android:id="@+id/chkRunAsLauncher"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="8dp"
                                            android:text="Run as Home Launcher" />

                                        <com.google.android.material.checkbox.MaterialCheckBox
                                            android:id="@+id/chkKioskMode"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="4dp"
                                            android:checked="false"
                                            android:text="Kiosk Mode" />

                                        <com.google.android.material.checkbox.MaterialCheckBox
                                            android:id="@+id/chkAutoRestartLauncher"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="4dp"
                                            android:checked="true"
                                            android:text="Auto-restart when HOME mode changes" />

                                        <com.google.android.material.checkbox.MaterialCheckBox
                                            android:id="@+id/chkMainHomePopoutFullWindow"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="4dp"
                                            android:text="Popout To Full Window" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
</LinearLayout>
        </androidx.core.widget.NestedScrollView>
