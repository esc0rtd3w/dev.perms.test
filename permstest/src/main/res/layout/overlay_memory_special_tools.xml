<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/memorySpecialOverlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMemorySpecialOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/overlayMemorySpecialHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Special Tools"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnOverlayMemorySpecialResetWindow"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/memory_overlay_header_button"
                    android:clickable="true"
                    android:contentDescription="Reset special tools window"
                    android:focusable="false"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="↻"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btnOverlayMemorySpecialClose"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="@drawable/memory_overlay_header_button"
                    android:clickable="true"
                    android:contentDescription="Close special tools"
                    android:focusable="false"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="X"
                    android:textSize="13sp" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:fillViewport="false"
                android:scrollbarStyle="insideOverlay"
                android:scrollbars="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingEnd="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="File Type Search"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:alpha="0.72"
                        android:text="Search readable memory for file magic bytes. Checked file-type matches can be exported as separate files."
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilOverlayMemorySpecialFileType"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Common type"
                                app:endIconMode="dropdown_menu"
                                app:expandedHintEnabled="false">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/ddOverlayMemorySpecialFileType"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:inputType="none"
                                    android:minHeight="34dp"
                                    android:paddingStart="12dp"
                                    android:paddingTop="5dp"
                                    android:paddingEnd="56dp"
                                    android:paddingBottom="5dp"
                                    android:scrollHorizontally="true"
                                    android:singleLine="true"
                                    android:textSize="10sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:hint="Custom type">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtOverlayMemorySpecialCustomType"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textNoSuggestions"
                                android:minHeight="34dp"
                                android:paddingStart="10dp"
                                android:paddingTop="5dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="5dp"
                                android:singleLine="true"
                                android:textSize="10sp" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOverlayMemorySpecialSearchType"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:paddingStart="4dp"
                        android:paddingTop="0dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="0dp"
                        android:singleLine="true"
                        android:text="Search File Type"
                        android:textSize="10sp"
                        app:cornerRadius="15dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Manual Import/Export"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:alpha="0.72"
                        android:text="Use Begin and End for manual export. If file-type matches are checked, Export saves each checked match separately."
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Begin">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtOverlayMemorySpecialBegin"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textNoSuggestions"
                                android:minHeight="34dp"
                                android:singleLine="true"
                                android:textSize="10sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:hint="End">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtOverlayMemorySpecialEnd"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textNoSuggestions"
                                android:minHeight="34dp"
                                android:singleLine="true"
                                android:textSize="10sp" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:hint="Import source path">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtOverlayMemorySpecialSourcePath"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textNoSuggestions"
                            android:minHeight="34dp"
                            android:singleLine="true"
                            android:textSize="10sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOverlayMemorySpecialExportType"
                            android:layout_width="0dp"
                            android:layout_height="28dp"
                            android:layout_weight="1"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="Export"
                            android:textSize="10sp"
                            app:cornerRadius="14dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOverlayMemorySpecialImportType"
                            android:layout_width="0dp"
                            android:layout_height="28dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="Import/Replace"
                            android:textSize="10sp"
                            app:cornerRadius="14dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Timer Finder"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:alpha="0.72"
                        android:text="Start a baseline, return to the app and let the timer change, then scan for decreased timer candidates."
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOverlayMemorySpecialTimerBaseline"
                            android:layout_width="0dp"
                            android:layout_height="28dp"
                            android:layout_weight="1"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="Timer Baseline"
                            android:textSize="10sp"
                            app:cornerRadius="14dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOverlayMemorySpecialTimerFind"
                            android:layout_width="0dp"
                            android:layout_height="28dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="Find Timers"
                            android:textSize="10sp"
                            app:cornerRadius="14dp" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/overlayMemorySpecialResizeHandle"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="6dp"
        android:alpha="0.82"
        android:background="@android:color/transparent"
        android:contentDescription="Resize special tools"
        android:src="@drawable/memory_overlay_resize_grip" />
</FrameLayout>
