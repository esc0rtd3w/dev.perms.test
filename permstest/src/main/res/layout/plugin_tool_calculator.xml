<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Calculator"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Integer calculator for hex, decimal, octal, and binary values. Use prefixes like 0x, 0b, or 0o when mixing bases."
                    android:textSize="12sp"
                    android:alpha="0.75"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Expression / value">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtToolsCalcInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:singleLine="true"
                            android:inputType="textNoSuggestions"
                            android:typeface="monospace"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilToolsCalcBase"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:hint="Base"
                        app:expandedHintEnabled="false"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/ddToolsCalcBase"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:includeFontPadding="false"
                            android:paddingTop="12dp"
                            android:paddingStart="12dp"
                            android:paddingBottom="12dp"
                            android:paddingEnd="64dp"
                            android:gravity="center_vertical"
                            android:ellipsize="end"
                            android:completionThreshold="0"
                            android:inputType="none"
                            android:focusable="false"
                            android:singleLine="true"
                            android:scrollHorizontally="true"
                            android:textSize="13sp"
                            android:text="Hex" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:columnCount="6">

                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcA" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="A" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcB" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="B" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcC" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="C" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcD" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="D" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcE" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="E" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcF" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="F" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc7" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="7" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc8" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="8" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc9" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="9" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcDiv" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="/" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcAnd" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="AND" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcOr" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="OR" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc4" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="4" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc5" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="5" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc6" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="6" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcMul" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="*" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcXor" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="XOR" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcNot" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="NOT" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc1" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="1" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc2" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="2" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc3" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="3" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcMinus" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="-" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcLsh" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="Lsh" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcRsh" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="Rsh" />

                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalc0" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="0" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcParenLeft" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="(" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcParenRight" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text=")" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcPlus" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="+" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcBackspace" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="⌫" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnToolsCalcClear" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:minWidth="0dp" android:text="C" />
                </GridLayout>

                <TextView
                    android:id="@+id/txtToolsCalcStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Enter a value or expression. Results update as you type."
                    android:textSize="12sp"
                    android:alpha="0.75" />

                <TextView android:id="@+id/txtToolsCalcHex" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:typeface="monospace" android:text="Hex: 0" />
                <TextView android:id="@+id/txtToolsCalcDec" android:layout_width="match_parent" android:layout_height="wrap_content" android:typeface="monospace" android:text="Dec: 0" />
                <TextView android:id="@+id/txtToolsCalcOct" android:layout_width="match_parent" android:layout_height="wrap_content" android:typeface="monospace" android:text="Oct: 0" />
                <TextView android:id="@+id/txtToolsCalcBin" android:layout_width="match_parent" android:layout_height="wrap_content" android:typeface="monospace" android:text="Bin: 0" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
