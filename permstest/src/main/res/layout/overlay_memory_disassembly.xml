<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/memoryDisasmOverlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMemoryDisasmOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/overlayMemoryDisasmHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Disassembly"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnOverlayMemoryDisasmResetWindow"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/memory_overlay_header_button"
                    android:clickable="true"
                    android:contentDescription="Reset disassembly window"
                    android:focusable="false"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="↻"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btnOverlayMemoryDisasmClose"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="@drawable/memory_overlay_header_button"
                    android:clickable="true"
                    android:contentDescription="Close disassembly"
                    android:focusable="false"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="X"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:hint="Address">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtOverlayMemoryDisasmAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textNoSuggestions"
                        android:minHeight="34dp"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:singleLine="true"
                        android:textSize="10sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:hint="Bytes">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtOverlayMemoryDisasmLength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:minHeight="34dp"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:singleLine="true"
                        android:text="1024"
                        android:textSize="10sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOverlayMemoryDisasmRefresh"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="4dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="4dp"
                    android:paddingBottom="0dp"
                    android:text="Refresh"
                    android:textSize="10sp"
                    app:cornerRadius="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOverlayMemoryDisasmAnalyze"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="4dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="4dp"
                    android:paddingBottom="0dp"
                    android:text="Analyze"
                    android:textSize="10sp"
                    app:cornerRadius="14dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="#44FFFFFF" />

                <CheckBox
                    android:id="@+id/chkOverlayMemoryDisasmSyncHex"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:buttonTint="?attr/colorPrimary"
                    android:checked="true"
                    android:gravity="center_vertical"
                    android:minHeight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="8dp"
                    android:text="Sync Hex"
                    android:textSize="10sp" />

                <RadioGroup
                    android:id="@+id/rgOverlayMemoryDisasmAutoMode"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbOverlayMemoryDisasmAutoRefresh"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:buttonTint="?attr/colorPrimary"
                        android:gravity="center_vertical"
                        android:minHeight="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="8dp"
                        android:text="Auto Refresh"
                        android:textSize="10sp" />

                    <RadioButton
                        android:id="@+id/rbOverlayMemoryDisasmAutoAnalyze"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:buttonTint="?attr/colorPrimary"
                        android:checked="true"
                        android:gravity="center_vertical"
                        android:minHeight="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:text="Auto Analyze"
                        android:textSize="10sp" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Ref Target">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtOverlayMemoryDisasmRefTarget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textNoSuggestions"
                        android:minHeight="34dp"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:singleLine="true"
                        android:textSize="10sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOverlayMemoryDisasmFindRefs"
                    android:layout_width="96dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="6dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="4dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="4dp"
                    android:paddingBottom="0dp"
                    android:text="Find Refs"
                    android:textSize="10sp"
                    app:cornerRadius="14dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowOverlayMemoryDisasmOutputScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="6dp"
                android:clipChildren="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtOverlayMemoryDisasmOutput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minHeight="240dp"
                    android:fontFamily="monospace"
                    android:gravity="top|start"
                    android:padding="6dp"
                    android:scrollbars="vertical"
                    android:scrollbarFadeDuration="0"
                    android:scrollbarSize="1dp"
                    android:scrollbarStyle="insideOverlay"
                    android:scrollbarThumbVertical="@drawable/memory_scrollbar_transparent"
                    android:scrollbarTrackVertical="@drawable/memory_scrollbar_transparent"
                    android:clickable="true"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:linksClickable="true"
                    android:textIsSelectable="false"
                    android:scrollHorizontally="true"
                    android:text="Disassembly view. Refresh reads bytes and decodes AArch64 instructions with the native Capstone bridge when available. Tap rows or address links for actions."
                    android:textSize="10sp" />

                <FrameLayout
                    android:id="@+id/frameOverlayMemoryDisasmScrollThumb"
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:clipChildren="false"
                    android:visibility="gone">

                    <SeekBar
                        android:id="@+id/seekOverlayMemoryDisasmScroll"
                        android:layout_width="250dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:max="1000"
                        android:progress="0"
                        android:rotation="90" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/overlayMemoryDisasmResizeHandle"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="6dp"
        android:alpha="0.82"
        android:background="@android:color/transparent"
        android:contentDescription="Resize disassembly"
        android:src="@drawable/memory_overlay_resize_grip" />
</FrameLayout>
