<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tabFiles"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Files"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/chkFilesUseShizuku"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Use Shizuku" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/chkFilesOpenKnown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Open known" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/chkFilesInternalApkInstall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Internal APK Install" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/chkFilesSplit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Split view" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="36dp"
                android:tag="files_home"
                android:text="Home" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minHeight="36dp"
                android:tag="files_sdcard"
                android:text="sdcard" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minHeight="36dp"
                android:tag="files_download"
                android:text="Download" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minHeight="36dp"
                android:tag="files_android_data"
                android:text="data" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minHeight="36dp"
                android:tag="files_android_media"
                android:text="media" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minHeight="36dp"
                android:tag="files_obb"
                android:text="OBB" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minHeight="36dp"
                android:tag="files_tmp"
                android:text="tmp" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minHeight="36dp"
                android:tag="files_root"
                android:text="root" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:contentDescription="New folder"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="36dp"
                android:padding="0dp"
                android:tag="files_mkdir_icon"
                android:text=""
                app:icon="@drawable/ic_create_new_folder_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:contentDescription="Paste"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="36dp"
                android:padding="0dp"
                android:tag="files_paste_icon"
                android:text=""
                app:icon="@drawable/ic_content_paste_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="21dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:tag="files_storage_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Storage: —"
                android:textSize="12sp"
                android:typeface="monospace" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/chkFilesScanRootDirectory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:checked="false"
                android:minHeight="36dp"
                android:text="Scan Root"
                android:textSize="12sp" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/chkFilesScanCurrentDirectory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:checked="false"
                android:minHeight="36dp"
                android:text="Scan Current"
                android:textSize="12sp" />
        </LinearLayout>

        <EditText
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:tag="files_filter"
            android:hint="Filter"
            android:singleLine="true"
            android:inputType="text"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:tag="files_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textSize="12sp"
        android:typeface="monospace" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/filesPaneLeft"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="40dp"
                    android:layout_height="36dp"
                    android:contentDescription="Up"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="36dp"
                    android:padding="0dp"
                    android:tag="files_up_left"
                    android:text=""
                    app:icon="@drawable/ic_folder_up_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp" />

                <TextView
                    android:id="@+id/txtFilesPathLeft"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="/"
                    android:textSize="12sp"
                    android:typeface="monospace"
                    android:ellipsize="start"
                    android:singleLine="true" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center_vertical"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:tag="files_refresh_left"
                    android:contentDescription="Refresh"
                    app:icon="@drawable/ic_refresh_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="20dp"
                    android:text="" />
            </LinearLayout>

            <ListView
                android:id="@+id/listFilesLeft"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:choiceMode="singleChoice"
                android:fastScrollEnabled="true"
                android:smoothScrollbar="true"
                android:scrollbarStyle="outsideInset"
                android:dividerHeight="1dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/filesPaneRight"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="40dp"
                    android:layout_height="36dp"
                    android:contentDescription="Up"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="36dp"
                    android:padding="0dp"
                    android:tag="files_up_right"
                    android:text=""
                    app:icon="@drawable/ic_folder_up_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp" />

                <TextView
                    android:id="@+id/txtFilesPathRight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="/"
                    android:textSize="12sp"
                    android:typeface="monospace"
                    android:ellipsize="start"
                    android:singleLine="true" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center_vertical"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:tag="files_refresh_right"
                    android:contentDescription="Refresh"
                    app:icon="@drawable/ic_refresh_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="20dp"
                    android:text="" />
            </LinearLayout>

            <ListView
                android:id="@+id/listFilesRight"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:choiceMode="singleChoice"
                android:fastScrollEnabled="true"
                android:smoothScrollbar="true"
                android:scrollbarStyle="outsideInset"
                android:dividerHeight="1dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
