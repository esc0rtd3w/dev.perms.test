<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="2dp"
        android:text="Backend"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0.75"
        android:paddingBottom="10dp"
        android:text="Choose the access backend and manage Shizuku, Internal Shizuku, LADB, and status checks. This is a cloned popout view; the main Backend card stays in place."
        android:textSize="12sp" />

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingBottom="12dp"
        android:text="Status"
        android:textSize="16sp" />

    <include
        android:id="@+id/includeExecModeSelector"
        layout="@layout/include_execmode_selector" />

    <TextView
        android:id="@+id/txtShizukuOptionsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:text="Shizuku Options"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/grpShizukuRow1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefresh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Refresh status" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRequest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Request permission" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRunId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Fetch server info" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/grpShizukuRow2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenShizuku"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Open" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartShizuku"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadShizuku"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Download" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtInternalShizukuOptionsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:paddingBottom="8dp"
        android:text="Internal Shizuku Options"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtInternalShizukuModeHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:alpha="0.8"
        android:text="Internal Shizuku uses its own Wireless Debugging pairing and server connection. After its binder is connected, no separate Request Permission prompt is needed."
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/rowInternalShizukuButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInternalShizukuPairStart"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pair &amp; Start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInternalShizukuStartServer"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Start Server" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInternalShizukuStopServer"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Stop Server" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowInternalShizukuWirelessSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInternalShizukuWirelessSettings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wireless Settings" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtInternalShizukuPairHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:alpha="0.8"
        android:text="Tip: Open Wireless debugging → Pair device with pairing code. PermsTest will auto-detect the port; you only enter the 6-digit code."
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtLadbOptionsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="LADB Options"
        android:textStyle="bold"
        android:visibility="gone" />

    <include
        android:id="@+id/includeExecModeLadb"
        layout="@layout/include_execmode_ladb"
        android:visibility="gone" />

</LinearLayout>
