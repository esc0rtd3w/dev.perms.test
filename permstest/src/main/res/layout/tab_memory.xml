<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tabMemory"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone"
    android:fillViewport="true"
    android:scrollbars="none"
    android:scrollbarStyle="insideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Memory Editor and Tools"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMemoryOverlayOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingBottom="2dp"
                    android:tag="collapsible_groupbox_header">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Overlay Options"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:tag="memory_popout_overlay_options"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="Pop out Overlay Options"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingLeft="6dp"
                        android:paddingRight="6dp"
                        android:text=""
                        app:icon="@drawable/ic_popout_open_in_new_24"
                        app:iconGravity="textStart"
                        app:iconTint="?attr/colorPrimary"
                        app:iconPadding="0dp"
                        app:iconSize="20dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:paddingBottom="10dp"
                    android:text="Configure package filtering, staging, and floating overlay behavior. Most scan, patch, dump, and special memory tools live in the overlay windows."
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryOpenOverlay"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Memory Scanner" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryOpenHexOverlay"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Hex Editor" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryOpenDisasmOverlay"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Disassembly" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryOpenSpecialTools"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Special Tools" />
                </LinearLayout>

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryOnlyRunningPackages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:text="Only Show Running Packages" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryShowRunningPackages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:text="Show Running Packages" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryExcludeSelfPackage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Exclude PermsTest from package lists" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryAutoStage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Auto Stage" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryOverlayShowSessionButtons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Show tool buttons in overlay" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryDisableOverlaysVrCompatible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disable Overlays (VR Compatible)" />

                <!-- Off by default: after Attach succeeds, complete payload JSON files in the
                     selected package folder can be auto-applied. -->
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryApplyPayloadsOnAttach"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apply Payloads On Attach" />

                <!-- On by default: payload apply should patch every bounded match
                     for original_hex instead of only the first matching instance. -->
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryApplyPayloadsToAllMatches"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Apply payloads to all found instances" />

                <!-- On by default: the overlay details log should list every
                     successfully patched payload address for easier verification. -->
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryShowAllPatchedAddresses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Show All Patched Addresses" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryWithoutPtrace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patch without ptrace (Android 9 and lower only)" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryUseOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open overlay controls when attaching" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryOverlayTransparent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transparent overlay window" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryOverlayResizable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resizable overlay window" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMemoryMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingBottom="2dp"
                    android:tag="collapsible_groupbox_header">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Memory"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:tag="memory_popout_memory"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="Pop out Memory"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingLeft="6dp"
                        android:paddingRight="6dp"
                        android:text=""
                        app:icon="@drawable/ic_popout_open_in_new_24"
                        app:iconGravity="textStart"
                        app:iconTint="?attr/colorPrimary"
                        app:iconPadding="0dp"
                        app:iconSize="20dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:paddingBottom="10dp"
                    android:text="Select a target package, stage apk-medit when needed, and clear the current memory session. Use overlays for scan, patch, dump, and advanced tools."
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:paddingBottom="4dp">

                    <ProgressBar
                        android:id="@+id/pbMemoryTargetPackagesLoading"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:indeterminate="true"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMemoryTargetPkg"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Target package"
                        app:expandedHintEnabled="false"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/edtMemoryTargetPkg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:includeFontPadding="false"
                            android:paddingTop="12dp"
                            android:paddingStart="12dp"
                            android:paddingBottom="12dp"
                            android:paddingEnd="64dp"
                            android:gravity="center_vertical"
                            android:ellipsize="end"
                            android:inputType="none"
                            android:singleLine="true"
                            android:scrollHorizontally="true"
                            android:textSize="13sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryRefreshTargetPackages"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Refresh" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryUsePackageTarget"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Use Package Target" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryStageTool"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Stage Tool" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryClearState"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Clear Session" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMemoryProcesses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingBottom="2dp"
                    android:tag="collapsible_groupbox_header">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Processes"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:tag="memory_popout_processes"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="Pop out Processes"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingLeft="6dp"
                        android:paddingRight="6dp"
                        android:text=""
                        app:icon="@drawable/ic_popout_open_in_new_24"
                        app:iconGravity="textStart"
                        app:iconTint="?attr/colorPrimary"
                        app:iconPadding="0dp"
                        app:iconSize="20dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:paddingBottom="8dp"
                    android:text="Select or refresh the target process before attaching. The overlay can also auto-select the most likely process for the chosen package."
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMemoryProcess"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Running process"
                        app:expandedHintEnabled="false"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/ddMemoryProcess"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="56dp"
                            android:includeFontPadding="false"
                            android:paddingTop="12dp"
                            android:paddingStart="12dp"
                            android:paddingBottom="12dp"
                            android:paddingEnd="64dp"
                            android:gravity="center_vertical"
                            android:ellipsize="end"
                            android:inputType="none"
                            android:singleLine="true"
                            android:scrollHorizontally="true"
                            android:textSize="13sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryRefreshProcesses"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Refresh" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryStartApp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Start App" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryStopApp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Stop App" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryAttach"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Attach" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryDetach"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Detach" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMemoryPayloadEditor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingBottom="2dp"
                    android:tag="collapsible_groupbox_header">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Payload Editor"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:tag="memory_popout_payload_editor"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="Pop out Payload Editor"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingLeft="6dp"
                        android:paddingRight="6dp"
                        android:text=""
                        app:icon="@drawable/ic_popout_open_in_new_24"
                        app:iconGravity="textStart"
                        app:iconTint="?attr/colorPrimary"
                        app:iconPadding="0dp"
                        app:iconSize="20dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:paddingBottom="8dp"
                    android:text="Browse and edit memory payload JSON files for the selected target package. ASCII fields can rebuild matching hex and mask bytes without using a separate converter."
                    android:textSize="12sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMemoryPayloadEditorPayload"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Payload JSON"
                    app:expandedHintEnabled="false"
                    app:endIconMode="dropdown_menu">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/ddMemoryPayloadEditorPayload"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="56dp"
                        android:includeFontPadding="false"
                        android:paddingTop="12dp"
                        android:paddingStart="12dp"
                        android:paddingBottom="12dp"
                        android:paddingEnd="64dp"
                        android:gravity="center_vertical"
                        android:ellipsize="end"
                        android:inputType="none"
                        android:singleLine="true"
                        android:scrollHorizontally="true"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chkMemoryPayloadEditorInstallBundled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:checked="true"
                    android:text="Install bundled payloads" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadEditorRefresh"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Refresh" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadEditorLoad"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Load/Edit" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadEditorNew"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="New" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadEditorDelete"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Delete" />
                </LinearLayout>



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadEditorEnable"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Enable" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadEditorDisable"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Disable" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadEditorClearMask"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Clear Mask" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtMemoryPayloadEditorStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:paddingTop="8dp"
                    android:text="Select a target package and press Refresh to list payload JSON files."
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMemoryRunPayloads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingBottom="2dp"
                    android:tag="collapsible_groupbox_header">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Run Payloads"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:tag="memory_popout_run_payloads"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="Pop out Run Payloads"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingLeft="6dp"
                        android:paddingRight="6dp"
                        android:text=""
                        app:icon="@drawable/ic_popout_open_in_new_24"
                        app:iconGravity="textStart"
                        app:iconTint="?attr/colorPrimary"
                        app:iconPadding="0dp"
                        app:iconSize="20dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:paddingBottom="8dp"
                    android:text="Queue enabled payload JSON files for the selected target package, then launch the app and apply the queue through the same path used by Launch With Payloads."
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadQueueAdd"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Add To Queue" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadQueueRemove"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Remove From Queue" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMemoryPayloadQueueRun"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="Run Payloads" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtMemoryPayloadQueueStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:paddingTop="8dp"
                    android:text="Queue payloads for the selected target package. Tap a queued row to select it; long-press to remove."
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/listMemoryPayloadQueue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:minHeight="44dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
